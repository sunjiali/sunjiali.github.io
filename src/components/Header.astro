---
import { siteConfig } from '../utils/site-config';

const currentPath = Astro.url.pathname;
const currentPage = currentPath === '/' ? 'about' : currentPath.split('/')[1];
---

<header>
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm fixed-top">
    <div class="container">
      <a class="navbar-brand title font-weight-lighter" href="/">
        <span class="brand-icon">👤</span>
        <span class="font-weight-bold">{siteConfig.firstName}</span> {siteConfig.lastName}
      </a>

      <button
        class="navbar-toggler collapsed"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          {siteConfig.navItems.map(item => (
            <li class={`nav-item ${currentPage === item.url.slice(1) ? 'active' : ''}`}>
              <a class="nav-link" href={item.url}>
                {item.title}
                {currentPage === item.url.slice(1) && <span class="sr-only">(current)</span>}
              </a>
            </li>
          ))}

          {siteConfig.theme.enableDarkMode && (
            <li class="nav-item">
              <button id="light-toggle" title="切换主题" aria-label="Toggle theme">
                <span id="light-toggle-system">🌓</span>
                <span id="light-toggle-dark">🌙</span>
                <span id="light-toggle-light">☀️</span>
              </button>
            </li>
          )}
        </ul>
      </div>
    </div>
  </nav>
</header>

<style>
  .navbar {
    background: var(--global-bg-color);
    border-bottom: 1px solid var(--global-divider-color);
    backdrop-filter: blur(10px);
  }
  
  .navbar-brand {
    color: var(--global-theme-color) !important;
    font-size: 1.1rem;
  }
  
  .brand-icon {
    margin-right: 0.5rem;
  }
  
  .nav-link {
    color: var(--global-text-color) !important;
    transition: color 0.3s ease;
  }
  
  .nav-link:hover {
    color: var(--global-theme-color) !important;
  }
  
  .nav-item.active .nav-link {
    color: var(--global-theme-color) !important;
    font-weight: 600;
  }
  
  #light-toggle {
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
  }
  
  #light-toggle span {
    display: none;
  }
  
  #light-toggle-system { display: inline; }
  
  :root:not([data-theme]) #light-toggle-system { display: inline; }
  :root[data-theme="dark"] #light-toggle-dark { display: inline; }
  :root[data-theme="light"] #light-toggle-light { display: inline; }
  
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>

<script>
  const toggle = document.getElementById('light-toggle');
  const root = document.documentElement;
  
  function getTheme() {
    return localStorage.getItem('theme') || 
           (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  }
  
  function setTheme(theme: string) {
    root.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }
  
  toggle?.addEventListener('click', () => {
    const current = getTheme();
    setTheme(current === 'dark' ? 'light' : 'dark');
  });
</script>
