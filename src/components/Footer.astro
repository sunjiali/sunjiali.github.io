---
import { siteConfig } from '../utils/site-config';
---
<footer class="sticky-bottom">
  <div class="container">
    <div class="footer-content">
      <span class="copyright">© {new Date().getFullYear()} {siteConfig.author.name}. All rights reserved.</span>
      <div class="footer-links">
        <a href="https://github.com/sunjiali" target="_blank" rel="noopener noreferrer" title="GitHub">🐙</a>
        <a href="mailto:{siteConfig.author.email}" title="Email">📧</a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--global-bg-color);
    border-top: 1px solid var(--global-divider-color);
    padding: 1.5rem 0;
    color: var(--global-text-color);
    font-size: 0.9rem;
  }
  
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .copyright {
    opacity: 0.8;
  }
  
  .footer-links {
    display: flex;
    gap: 1rem;
  }
  
  .footer-links a {
    font-size: 1.2rem;
    text-decoration: none;
    transition: transform 0.3s ease;
  }
  
  .footer-links a:hover {
    transform: translateY(-2px);
  }
  
  @media (max-width: 576px) {
    .footer-content {
      justify-content: center;
      text-align: center;
    }
  }
</style>
