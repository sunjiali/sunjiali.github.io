---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
---

<Layout title={`关于 - ${SITE.title}`}>
  <article class="max-w-3xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="prose prose-lg max-w-none">
      <h1 class="text-4xl font-bold text-gray-900 mb-8">
        关于我
      </h1>
      <p class="text-lg text-gray-700 mb-6">
        你好！我是{SITE.title}，是一名热爱技术的开发者。
      </p>
      <h2 class="text-2xl font-semibold text-gray-900 mb-4 mt-8">
        技术栈
      </h2>
      <p class="text-lg text-gray-700 mb-6">
        这个网站使用以下技术栈构建：
      </p>
      <ul class="list-disc list-inside text-gray-700 space-y-2 mb-6">
        <li><strong class="text-blue-600">Astro 5</strong> - 现代静态网站生成器</li>
        <li><strong class="text-blue-600">TypeScript</strong> - 类型安全的 JavaScript</li>
        <li><strong class="text-blue-600">Tailwind CSS 4</strong> - 实用优先的 CSS 框架</li>
        <li><strong class="text-blue-600">Vercel</strong> - 云端部署平台</li>
        <li><strong class="text-blue-600">Biome</strong> - 快速的 linter 和 formatter</li>
      </ul>
      <h2 class="text-2xl font-semibold text-gray-900 mb-4 mt-8">
        联系方式
      </h2>
      <p class="text-lg text-gray-700">
        欢迎通过邮件联系我：<a href="mailto:sunjiali@aliyun.com" class="text-blue-600 hover:underline">sunjiali@aliyun.com</a>
      </p>
    </div>
  </article>
</Layout>
