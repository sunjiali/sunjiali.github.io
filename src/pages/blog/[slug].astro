---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.slug },
      props: post,
    }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
  <article class="max-w-3xl mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <header class="mb-8 border-b border-gray-200 pb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">
        {post.data.title}
      </h1>
      <div class="flex items-center justify-between text-sm text-gray-500">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </time>
        {post.data.tags && (
          <div class="flex gap-2">
            {post.data.tags.map((tag) => (
              <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
      {post.data.description && (
        <p class="text-gray-600 mt-4">
          {post.data.description}
        </p>
      )}
    </header>
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
    <footer class="mt-12 pt-8 border-t border-gray-200">
      <a
        href="/blog"
        class="inline-flex items-center text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors"
      >
        ← 返回博客列表
      </a>
    </footer>
  </article>
</Layout>
