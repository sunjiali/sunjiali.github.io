---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => Math.floor(b.data.pubDate.valueOf() / 1000) - Math.floor(a.data.pubDate.valueOf() / 1000)
);
---

<Layout title="Blog">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold text-gray-900 mb-8">Blog Posts</h1>

    <div class="grid gap-8">
      {allPosts.map((post) => (
        <article class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
          <h2 class="text-2xl font-bold mb-2">
            <a href={`/blog/${post.slug}`} class="text-gray-900 hover:text-blue-600 transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-gray-600 mb-4">{post.data.description}</p>
          <div class="flex justify-between items-center text-sm text-gray-500">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
            {post.data.tags && (
              <div class="flex gap-2">
                {post.data.tags.map((tag) => (
                  <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
