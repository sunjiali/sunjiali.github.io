---
interface Props {
  title: string;
}

const { title } = Astro.props;

import { SITE } from '../config';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="孙佳利的个人网站和博客" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - {SITE.title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <div class="min-h-screen flex flex-col">
      <nav class="border-b border-gray-200 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 justify-between">
            <div class="flex">
              <a href="/" class="flex items-center space-x-2 text-gray-900 hover:text-gray-600 transition-colors">
                <span class="text-xl font-bold">{SITE.title}</span>
              </a>
            </div>
            <div class="hidden sm:flex sm:space-x-8">
              <a href="/" class="text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors">
                首页
              </a>
              <a href="/about" class="text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors">
                关于
              </a>
              <a href="/blog" class="text-sm font-medium text-gray-700 hover:text-blue-600 transition-colors">
                博客
              </a>
            </div>
          </div>
        </div>
      </nav>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="border-t border-gray-200 bg-white mt-auto">
        <div class="max-w-5xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
          <p class="text-center text-sm text-gray-500">
            &copy; {new Date().getFullYear()} {SITE.title}. All rights reserved.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
