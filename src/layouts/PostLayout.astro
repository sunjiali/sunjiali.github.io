---
import Layout from './Layout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  categories?: string[];
  image?: string;
}

const { title, date, description, tags, categories, image } = Astro.props;
---

<Layout title={`${title} - 孙佳利`} description={description} image={image}>
  <article class="article-container">
    <header class="article-header">
      {categories && categories.length > 0 && (
        <div class="article-category">{categories[0]}</div>
      )}
      <h1 class="article-title">{title}</h1>
      {description && (
        <p class="article-description">{description}</p>
      )}
      <div class="article-meta">
        <span class="meta-item">
          📅 {date.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </span>
        <span class="meta-item">👤 孙佳利</span>
      </div>
      {tags && tags.length > 0 && (
        <div class="article-tags">
          {tags.map(tag => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="article-content">
      <slot />
    </div>

    <footer class="article-footer">
      <div class="share-section">
        <span>觉得有用？分享给朋友吧！</span>
      </div>
      <a href="/blog" class="back-link">
        ← 返回博客列表
      </a>
    </footer>
  </article>
</Layout>

<style>
  .article-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--global-divider-color);
  }

  .article-category {
    display: inline-block;
    background: var(--global-theme-color);
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .article-title {
    color: var(--global-text-color);
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .article-description {
    color: var(--global-text-color);
    opacity: 0.85;
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--global-text-color);
    opacity: 0.7;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .article-tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--global-bg-secondary-color);
    color: var(--global-theme-color);
    padding: 0.25rem 0.75rem;
    border-radius: 15px;
    font-size: 0.85rem;
    border: 1px solid var(--global-theme-color);
    opacity: 0.9;
  }

  .article-content {
    line-height: 1.9;
    font-size: 1.05rem;
    color: var(--global-text-color);
  }

  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3) {
    color: var(--global-text-color);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .article-content :global(h1) { font-size: 1.8rem; }
  .article-content :global(h2) { font-size: 1.5rem; border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.5rem; }
  .article-content :global(h3) { font-size: 1.25rem; }

  .article-content :global(p) {
    margin-bottom: 1.2rem;
  }

  .article-content :global(a) {
    color: var(--global-theme-color);
    text-decoration: none;
    border-bottom: 1px dashed var(--global-theme-color);
    transition: border-bottom 0.2s ease;
  }

  .article-content :global(a:hover) {
    border-bottom: 1px solid var(--global-theme-color);
  }

  .article-content :global(code) {
    background: var(--global-code-bg-color);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .article-content :global(pre) {
    background: var(--global-bg-secondary-color);
    padding: 1.2rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--global-divider-color);
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--global-theme-color);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    opacity: 0.9;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .article-content :global(th),
  .article-content :global(td) {
    border: 1px solid var(--global-divider-color);
    padding: 0.75rem;
    text-align: left;
  }

  .article-content :global(th) {
    background: var(--global-bg-secondary-color);
    font-weight: 600;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--global-divider-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .share-section {
    color: var(--global-text-color);
    opacity: 0.7;
    font-size: 0.95rem;
  }

  .back-link {
    color: var(--global-theme-color);
    text-decoration: none;
    font-weight: 500;
    transition: transform 0.2s ease;
  }

  .back-link:hover {
    transform: translateX(-4px);
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 1.8rem;
    }

    .article-meta {
      flex-direction: column;
      gap: 0.5rem;
    }

    .article-footer {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
