    "astro": "^5.16.6",
    "dayjs": "^1.11.19",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "lodash.kebabcase": "^4.1.1",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.25.5",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash.kebabcase": "^4.1.9",
    "autoprefixer": "^10.4.23"
